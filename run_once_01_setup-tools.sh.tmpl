#!/bin/bash

set -euo pipefail

if [ ! -d ~/.local/share/tmux/plugins/tpm ]; then
    git clone https://github.com/tmux-plugins/tpm ~/.local/share/tmux/plugins/tpm
fi

if [ ! -d ~/.local/share/zinit/zinit.git ]; then
    git clone https://github.com/zdharma-continuum/zinit.git ~/.local/share/zinit/zinit.git
fi

if [ ! -d ~/.config/nvim ]; then
    git clone https://github.com/NvChad/starter ~/.config/nvim
fi

# if mise is not installed, install it
if ! command -v mise >/dev/null 2>&1; then
    curl https://mise.run | sh
    mkdir -p ~/.config/mise
    touch ~/.config/mise/config.local.toml
fi

mkdir -p ~/.config/zsh/completions

if [ ! -f ~/.config/zsh/profile ]; then
    touch ~/.config/zsh/profile
fi

if command -v zsh >/dev/null 2>&1; then
    if [ "${SHELL:-}" != "$(command -v zsh)" ]; then
        echo 'run chsh -s "$(command -v zsh)" to change your default shell to zsh after applying dotfiles.'
    fi
else
    echo "zsh is not installed; skipping default shell check." >&2
fi

if [ "${ZDOTDIR:-}" != "$HOME/.config/zsh" ]; then
    echo 'run export ZDOTDIR="$HOME/.config/zsh" >> /etc/zshenv'
    echo 'to set ZDOTDIR to ~/.config/zsh'
fi
